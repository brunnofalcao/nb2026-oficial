{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/programacao/plenaria-principal", "destination": "/plenaria-principal.html" },
    { "source": "/programacao/nutricao-esportiva", "destination": "/nutricao-esportiva.html" },
    { "source": "/programacao/medbrasil", "destination": "/medbrasil.html" },
    { "source": "/programacao/corrida-de-rua", "destination": "/corrida-de-rua.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
